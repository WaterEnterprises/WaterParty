# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Turso Database Configuration (libSQL)
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Stripe Configuration (Payment Processing)
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Telegram Bot Configuration (for admin notifications about new registrations/logins)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Java JDK path (required for Android builds via npx cap run android)
# Points to the JDK bundled with Android Studio
JAVA_HOME="/c/Program Files/Android/Android Studio/jbr"

# Admin User IDs (comma-separated) for access to admin-only API endpoints
ADMIN_USER_IDS="user_id_here"

# Stripe API Keys (for fundraiser payments — get these from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Rate Limiting (optional — adjust for local development)
# Defaults are generous: auth=50, api=200, payment=30, upload=500 per 15 min
# In development mode (NODE_ENV=development), defaults are doubled automatically.
# Set these to explicit values if you want precise control.
# RATE_LIMIT_AUTH=100
# RATE_LIMIT_API=400
# RATE_LIMIT_PAYMENT=60
# RATE_LIMIT_UPLOAD=1000
# RATE_LIMIT_WINDOW_MS=900000

# AdMob (for ad monetization — get these from https://apps.admob.com)
# Test IDs from Google are used as fallback when not set.
# These are injected at build time by scripts/build-web.js via Bun's `define`.
ADMOB_APP_ID="ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX"
ADMOB_INTERSTITIAL_ID="ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXX"
ADMOB_REWARDED_ID="ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXX"
