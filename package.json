{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "bun --hot run server/index.ts",
    "dev:web": "bash scripts/dev-web.sh",
    "dev:device": "bash scripts/run-android-dev.sh",
    "build:capacitor": "NODE_ENV=production bun run build:css && NODE_ENV=production bun run build:web && bun run build:copy",
    "build:render": "NODE_ENV=production bun run build:capacitor && bun run build:server",
    "build": "bun run build:render",
    "start": "bun run dist/server.cjs",
    "build:css": "bunx @tailwindcss/cli -i ./src/index.css -o ./dist/assets/index.css",
    "build:web": "bun run scripts/build-web.js",
    "build:copy": "cp index.html dist/index.html && cp public/* dist/ 2>/dev/null; cp branding.jpg dist/ 2>/dev/null; cp neue_frutiger_world_regular.ttf dist/ 2>/dev/null; echo 'Static assets copied'",
    "build:server": "bun build ./server/index.ts --outfile=./dist/server.cjs --target=bun --packages=external && bun run scripts/generate-dist-package.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint ."
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@libsql/client": "^0.17.3",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "hono": "^4.12.25",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.17.0",
    "sharp": "^0.34.5",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.61.0"
  }
}
